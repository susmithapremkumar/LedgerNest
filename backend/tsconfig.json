{
  "compilerOptions": {
    "target": "ES2022",

    "module": "nodenext",

    "moduleResolution": "nodenext",

    "rootDir": "./src",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "types": ["node", "express"]
  },

  "include": [
    "src"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}